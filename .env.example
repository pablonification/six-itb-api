# SIX API Server Configuration
# Copy this file to .env and update values for your deployment

# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# CORS Configuration
# Use comma-separated list for multiple origins, or * for all
CORS_ORIGIN=*

# Database Configuration
# Use file path for persistent storage or :memory: for in-memory
DB_PATH=./data/sessions.db
API_KEY_DB_PATH=./data/api_keys.db

# Authentication Configuration
API_KEY_ENABLED=true

# Master Admin Key (for initial API key creation)
# IMPORTANT: Generate a secure random key and keep it secret!
# Generate with: openssl rand -hex 32
MASTER_ADMIN_KEY=your-secure-master-key-here

# Browser Configuration (for Playwright)
# Set to true for headless mode (recommended for production)
BROWSER_HEADLESS=true